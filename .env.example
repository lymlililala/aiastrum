SUPABASE_URL="https://tixgzezefjjsyuzgdhcd.supabase.co"
# 新版公开 key（替代 anon），形如 sb_publishable_xxx
SUPABASE_PUBLISHABLE_KEY=""
# 新版私密 key（替代 service_role），仅服务端，形如 sb_secret_xxx —— 切勿提交到版本库
